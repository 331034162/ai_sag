# 大模型 Profile 配置文件示例
# ========================================================================
# 复制本文件为 llm_profiles.yaml，按需修改后提交到 .gitignore（避免泄漏 api_key）
#
# 仅配置模型的"连接身份"信息：base_url / api_key / model / timeout / max_retries
# 每个顶层 key 是一个 profile 名（自定义），在 .env 中通过
#   SAG_LLM_PROFILE_<场景>_LLM_NAME=<profile 名>
# 引用。
#
# api_key 直接写明（llm_profiles.yaml 已在 .gitignore 中，不会被提交）。
#
# 后端由 factory 按 model 自动判断（无法手动配置）：
#   - model 在 llamaindex 的 OpenAI 官方模型列表内（gpt-4o / o1 / o3 等）→ openai 后端
#   - 否则 → openai_like 后端（DeepSeek、阿里云百炼、vLLM 等兼容接口）
#
# 同一个 profile 可被多个场景复用。
# 在 .env 中按场景独立配置 ADDITIONAL_KWARGS / EXTRA_BODY（详见 .env.example）。
# ========================================================================

# 阿里云百炼 - qwen3.6-27b（思考模式，用于答案生成）
qwen_thinking:
  base_url: "https://dashscope.aliyuncs.com/compatible-mode/v1"
  api_key: "sk-your-dashscope-api-key-here"
  model: "qwen3.6-27b"
  timeout: 120
  max_retries: 3

# DeepSeek - deepseek-chat（普通对话，用于抽取/重排等结构化任务）
deepseek_chat:
  base_url: "https://api.deepseek.com"
  api_key: "sk-your-deepseek-api-key-here"
  model: "deepseek-chat"
  timeout: 120
  max_retries: 3