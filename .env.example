# ==============================================================
# ai_sag 环境配置模板
#
# 使用方法：
#   1. 复制此文件为 .env：
#      Linux/Mac:  cp .env.example .env
#      Windows:    copy .env.example .env
#   2. 编辑 .env，填入你自己的配置值
#   3. .env 文件不会被 git 追踪（已在 .gitignore 中）
#
# 注意：项目会自动从 config.py 所在目录逐级向上搜索 .env 文件，
#       你只需把它放在 ai_sag/ 目录下即可，无需关心仓库的 clone 路径。
#
# 所有配置项均有合理默认值，注释中的"默认"值即代码中的实际默认值，
# 与 config.py 保持严格同步。初次使用只需填写上方必填项即可。
# ==============================================================

# ==============================================================
# 必填：关系数据库后端
# ==============================================================
# 数据库后端切换：mysql（默认）| postgresql
AISAG_DB_BACKEND=mysql

# ---- MySQL（AISAG_DB_BACKEND=mysql 时使用）----
SAG_MYSQL_HOST=localhost
SAG_MYSQL_PORT=3306
SAG_MYSQL_DATABASE=sag
SAG_MYSQL_USER=root
SAG_MYSQL_PASSWORD=your_password

# ---- PostgreSQL（AISAG_DB_BACKEND=postgresql 时使用）----
# 前置条件：PG 已安装，并创建数据库（CREATE DATABASE sag;）
# 表结构首次启动自动创建（schema_pg.sql）
SAG_PG_HOST=localhost
SAG_PG_PORT=5432
SAG_PG_DATABASE=sag
SAG_PG_USER=postgres
SAG_PG_PASSWORD=your_password

# ==============================================================
# 必填：向量库后端
# ==============================================================
# 向量库后端（默认 chroma）：
#   chroma   — 本地轻量持久化，无需外部服务（开发/小规模场景推荐）
#   faiss    — 单机内存索引 + 本地持久化，检索速度极快（本地大规模推荐）
#              FAISS 后端需配合关系库（MySQL/PG）的 faiss_*_map 映射表反查 UUID，
#              系统会在 faiss 后端时自动启用映射表（faiss_map_enabled=True）
#   milvus   — 分布式向量库，需启动 Milvus 服务（生产部署推荐）
#   pgvector — 基于 PostgreSQL + pgvector 扩展，与业务数据共存，支持 SQL 联查
AISAG_VECTOR_STORE_BACKEND=chroma

# 向量维度（必须与 embedding 模型输出维度一致）：
#   bge-small-zh-v1.5：512（默认）
#   Qwen3-Embedding-0.6B：1024
# 切换 embedding 后端时同步修改此项，否则维度不匹配会报错
AISAG_VECTOR_STORE_DIM=512

# ---- Chroma 后端 ----
# Chroma 向量库持久化路径（默认：项目根/.chroma）
# AISAG_CHROMA_PATH=./.chroma

# ---- FAISS 后端 ----
# 持久化目录：每个 collection 写 {name}.index + {name}.meta.json 两个文件
# AISAG_FAISS_PATH=./.faiss

# ---- Milvus 后端 ----
# Milvus 服务地址（docker 启动默认 localhost:19530）
# AISAG_MILVUS_URI=http://localhost:19530
# Milvus 鉴权 token（无认证服务可留空）
# AISAG_MILVUS_TOKEN=
# 集合名前缀：5 个 collection 会创建为 {prefix}chunks / {prefix}event_titles / ...
# 多实例共享同一 Milvus 时通过前缀隔离
# AISAG_MILVUS_COLLECTION_PREFIX=sag_
# 是否覆盖已有集合（True=每次启动重建；False=保留已有数据，追加写入）
# AISAG_MILVUS_OVERWRITE=false

# ---- PGVector 后端 ----
# PostgreSQL 连接串：postgresql://{user}:{password}@{host}:{port}/{database}
# 前置条件：PG 已安装 pgvector 扩展（CREATE EXTENSION vector;）
# AISAG_PG_CONNECTION_STRING=postgresql://postgres:postgres@localhost:5432/sag
# Schema 名（默认 public）
# AISAG_PG_SCHEMA_NAME=public
# 表名前缀：5 个 collection 会创建为 {prefix}chunks / {prefix}event_titles / ...
# AISAG_PG_TABLE_PREFIX=sag_
# 是否使用 HNSW 索引（True=HNSW 速度快但写入慢；False=IVM_FLAT 精确检索）
# AISAG_PG_HNSW_INDEX=true
# 是否使用异步驱动（asyncpg）：True=异步连接池，False=同步 psycopg2
# AISAG_PG_ASYNC=true

# ==============================================================
# 必填：Embedding 模型
# ==============================================================
# 后端选择：bge（默认，轻量稳定，CLS pooling）| qwen3（精度高，last_token pooling + 查询指令前缀）
SAG_EMBEDDING_BACKEND=bge
# 模型本地路径（两种后端共用此变量，切后端时同步修改路径）
#   bge:   推荐 bge-small-zh-v1.5，下载：modelscope download --model AI-ModelScope/bge-small-zh-v1.5
#   qwen3: 推荐 Qwen3-Embedding-0.6B，下载：modelscope download --model Qwen/Qwen3-Embedding-0.6B
SAG_EMBEDDING_MODEL_PATH=/path/to/bge-small-zh-v1.5

# ---- Embedding 可选参数（有合理默认值，初次使用无需修改）----
# 推理设备（默认 cpu；GPU 环境改 cuda，无 CUDA 时 qwen3 后端自动降级到 cpu）
# SAG_EMBEDDING_DEVICE=cpu
# tokenizer 最大长度（默认 8192；bge 后端会自动压缩到模型上限 512，超长 chunk 会被截断）
# SAG_EMBEDDING_MAX_LENGTH=8192
# 是否对向量做 L2 归一化（默认 true，适配余弦相似度）
# SAG_EMBEDDING_NORMALIZE=true
# 批处理大小（默认 32，按批送入模型；0=不切批一次性送入，可能 OOM）
# SAG_EMBEDDING_BATCH_SIZE=32
# qwen3 查询指令前缀（仅 qwen3 后端生效；默认为通用检索指令）
# SAG_EMBEDDING_QUERY_INSTRUCTION=Instruct: Given a query, retrieve relevant passages from the knowledge base\nQuery:

# ==============================================================
# 必填：LLM 多场景配置（配合 llm_profiles.yaml）
# ==============================================================
# profile 模板见 llm_profiles.yaml.example，api_key 直接写在 yaml 中。
# 思考模式规则：
#   - ANSWER 场景可开启思考（enable_thinking / reasoning_effort）——适合复杂推理问答
#   - 抽取/重排场景（GENRE_CLASSIFY / EVENT_EXTRACT / ENTITY_EXTRACT / RERANK）
#     禁止开启思考——会破坏 structured_predict 的 JSON 解析
#   - QUERY_REWRITE 重写需快速稳定，不建议开启思考

# ---- 场景：GENRE_CLASSIFY 文档体裁分类（离线，禁止思考）----
# 作用：入库时对每篇文档判断文体（news/contract/report/...），驱动抽取规则
# 模型：DeepSeek deepseek-chat（普通 chat，输出需稳定 JSON）
# temperature=0 + seed 固定输出，便于复现
SAG_LLM_PROFILE_GENRE_CLASSIFY_LLM_NAME=deepseek_chat
SAG_LLM_PROFILE_GENRE_CLASSIFY_ADDITIONAL_KWARGS={"temperature": 0.0, "seed": 42}

# ---- 场景：EVENT_EXTRACT 事件抽取（离线，禁止思考）----
# 作用：对每个 chunk 抽取结构化事件（title/summary/entities/time/role）
# 模型：DeepSeek deepseek-chat（structured_predict 调用，思考会破坏 JSON 解析）
# temperature=0 + seed 固定输出
SAG_LLM_PROFILE_EVENT_EXTRACT_LLM_NAME=deepseek_chat
SAG_LLM_PROFILE_EVENT_EXTRACT_ADDITIONAL_KWARGS={"temperature": 0.0, "seed": 42}

# ---- 场景：QUERY_REWRITE 查询重写（在线，不建议思考）----
# 作用：把多轮对话改写为独立查询，做指代消解
# 模型：DeepSeek deepseek-chat（普通 chat，重写需快速稳定）
# 未配 ADDITIONAL_KWARGS 时 factory 用空字典兜底（temperature 默认 0.0）
SAG_LLM_PROFILE_QUERY_REWRITE_LLM_NAME=deepseek_chat

# ---- 场景：ENTITY_EXTRACT 查询实体抽取（在线，禁止思考）----
# 作用：从用户查询中抽取实体（人名/机构/事件名等）用于图谱召回
# 模型：DeepSeek deepseek-chat（structured_predict 调用，思考会破坏 JSON 解析）
# temperature=0 + seed 固定输出
SAG_LLM_PROFILE_ENTITY_EXTRACT_LLM_NAME=deepseek_chat
SAG_LLM_PROFILE_ENTITY_EXTRACT_ADDITIONAL_KWARGS={"temperature": 0.0, "seed": 42}

# ---- 场景：RERANK LLM 精排（在线，禁止思考）----
# 作用：对召回的候选事件打分排序，挑选最相关的 Top-K
# 模型：DeepSeek deepseek-chat（structured_predict 调用，思考会破坏 JSON 解析）
# temperature=0 + seed 固定输出
SAG_LLM_PROFILE_RERANK_LLM_NAME=deepseek_chat
SAG_LLM_PROFILE_RERANK_ADDITIONAL_KWARGS={"temperature": 0.0, "seed": 42}

# ---- 场景：ANSWER 答案生成（在线，可开启思考）----
# 作用：根据检索到的事件生成自然语言回答
# 模型：阿里云百炼 qwen3.6-27b（思考模型，适合复杂推理问答）
# temperature=0.7 增加回答多样性，max_tokens=12288 给思考留足空间
# extra_body.enable_thinking=true 显式开启思考模式
SAG_LLM_PROFILE_ANSWER_LLM_NAME=qwen_thinking
SAG_LLM_PROFILE_ANSWER_ADDITIONAL_KWARGS={"temperature": 0.7, "max_tokens": 12288}
SAG_LLM_PROFILE_ANSWER_EXTRA_BODY={"enable_thinking": true}

# ==============================================================
# 以下是可选配置（有合理默认值，初次使用无需修改）
# ==============================================================

# ---- 关系库连接池 ----
# MySQL 连接池（AISAG_DB_BACKEND=mysql 时生效）
# AISAG_MYSQL_POOL_SIZE=10                # 连接池大小（默认 10）
# AISAG_MYSQL_MAX_OVERFLOW=5              # 最大溢出连接数（默认 5）
# AISAG_MYSQL_POOL_TIMEOUT=30             # 获取连接超时秒数（默认 30）
# AISAG_MYSQL_POOL_RECYCLE=3600           # 连接回收秒数（默认 3600，防 8 小时断连）
# PostgreSQL 连接池（AISAG_DB_BACKEND=postgresql 时生效）
# AISAG_PG_POOL_SIZE=10
# AISAG_PG_MAX_OVERFLOW=5
# AISAG_PG_POOL_TIMEOUT=30
# AISAG_PG_POOL_RECYCLE=3600

# ---- 文档切分（默认 semantic 语义切分）----
# 切分模式：semantic（默认，语义完整最适合事件抽取）| auto | markdown | sentence | token | code
# AISAG_SPLITTER_MODE=semantic
# AISAG_CHUNK_SIZE=8192                   # chunk 大小（默认 8192）
# AISAG_CHUNK_OVERLAP=800                 # chunk 重叠（默认 800，防事件被切断）
# AISAG_BREAKPOINT_PERCENTILE=95          # 语义断点分位阈值（默认 95，越小切得越碎）
# AISAG_SPLITTER_LANGUAGE=python          # code 模式的编程语言（默认 python）

# ---- 文本清洗（默认全开，适配大多数文档；特殊场景可关闭某项）----
# AISAG_CLEANER_STRIP_HTML=true           # 去 HTML/XML 标签（默认 true）
# AISAG_CLEANER_MERGE_HARD_BREAKS=true    # 合并硬断行（默认 true；md/xlsx/xls/csv 自动跳过）
# AISAG_CLEANER_COLLAPSE_BLANK_LINES=true # 压缩多余空行（默认 true）
# AISAG_CLEANER_NORMALIZE_WHITESPACE=true # 规整空白/全角空格（默认 true）
# AISAG_CLEANER_PROTECT_LIST_ITEMS=true   # 列表项保护（默认 true，避免列表项被压成一行）

# ---- 文档解析 ----
# OCR 引擎：rapidocr（默认，轻量）| paddleocr（高精度但重）
# AISAG_DOC_OCR_BACKEND=rapidocr
# 是否对 PDF/Word 中的图片做 OCR（默认 true，关闭=false 入库更快但会丢失图片文字）
# AISAG_DOC_OCR_IMAGES=true
# PDF 扫描件转 markdown 模式：direct（默认，快）| pymupdf4llm（表格列对齐更准但可能误判）
# AISAG_PDF_MARKDOWN_MODE=direct
# 上传/解析临时目录（默认：项目根/tmp）
# AISAG_UPLOAD_TMP_DIR=./tmp

# ---- 检索参数（SAG 论文 3.3/3.4 + 项目扩展）----
# 核心召回阈值与开关
# AISAG_SIMILARITY_THRESHOLD=0.4          # 事件召回/粗排/chunk 召回相似度阈值（默认 0.4）
# AISAG_ENTITY_EXPAND_ENABLED=true        # 实体向量扩展总开关（默认 true；false=仅 SQL 精确匹配）
# AISAG_ENTITY_EXPAND_THRESHOLD=0.5       # 实体向量扩展相似度阈值（默认 0.5，独立于事件召回）
# AISAG_ENTITY_EXPAND_TOPK=20             # 每个查询实体向量召回近邻数（默认 20）
# AISAG_MAX_HOPS=2                        # BFS 最大跳数（默认 2）
# AISAG_SUB_STRATEGY=hopllm               # 多跳扩展策略：hopllm（默认，动态停止）| multi（固定跳数）
# AISAG_HOP_RELEVANCE_THRESHOLD=0.15      # hopllm 动态停止阈值：新跳最佳分<此值终止扩展（默认 0.15，安全阀）
# AISAG_HOP_SEED_TOPK=8                   # hopllm 每跳保留种子事件数（默认 8，防爆炸）
# AISAG_FUSION=concat                     # 双路融合：concat=两路拼接 | supplement=事件为主向量补足
# 种子事件向量召回策略：title（标题）| summary（摘要）| mixed（默认双路并发合并）
# AISAG_SEED_RECALL=mixed

# BFS 边界实体预算与相关性筛选
# AISAG_ENTITY_FRONTIER_BUDGET=100        # 每跳边界实体数上限（默认 100，论文 Section 4.4）
# BFS 边界实体相关性筛选（默认开启）：
#   开启后每跳对新增实体按 综合分=(1-α)*IDF(度数倒数) + α*query相似度 截断，
#   抑制"众邦银行"等高频枢纽实体桥接噪声事件；关闭则退回随机截断。
# AISAG_ENTITY_FRONTIER_FILTER=true
# 综合分中 query 相似度权重 α（0~1，默认 0.6，越大越偏向语义相关性）
# AISAG_ENTITY_FRONTIER_QUERY_WEIGHT=0.6

# 实体度数离群过滤（枢纽实体抑制）
# 离群检测方法：otsu（默认，数据驱动自动阈值）| percentile | mad | tukey | none（关闭）
# AISAG_ENTITY_DEGREE_METHOD=otsu
# AISAG_ENTITY_DEGREE_ABS_MAX=50          # 度数绝对硬上限（默认 50，度数>50 的实体直接剔除；0=关闭）
# AISAG_ENTITY_DEGREE_PERCENTILE=95       # percentile 法分位点（默认 P95，剔除最高 5% 枢纽）
# AISAG_ENTITY_DEGREE_OUTLIER_K=3.0       # mad/tukey 法离群倍数 k（默认 3.0，越大越保守；k≥5 近似关闭）
# AISAG_ENTITY_DEGREE_MIN_BATCH=10        # BFS 边界最小触发 batch（默认 10，实体数<10 跳过统计检测）

# 种子实体过滤（独立于 BFS，参数更保守，因种子更宝贵断链代价大）
# AISAG_SEED_ENTITY_BUDGET=20             # 种子实体总量硬上限（默认 20，精确匹配+向量扩展去重后）
# AISAG_SEED_ENTITY_MIN_BATCH=15          # 种子离群检测最小 batch（默认 15，比 BFS 更保守）
# AISAG_SEED_ENTITY_MIN_KEEP=8            # 种子过度过滤保护下限（默认 8，剩余<max(len//2, 8) 则回退）

# 粗排/精排
# AISAG_MAX_EVENTS=100                    # 粗排候选事件数 Kcand（默认 100）
# AISAG_COARSE_THRESHOLD=0                # 粗排相似度裁剪（默认 0=关闭，仅排序截断）
# AISAG_RERANK_TOP_K=5                    # LLM 重排保留事件数 Kevent（默认 5）
# AISAG_RERANK_CANDIDATE_LIMIT=100        # 送入 LLM 重排最大候选数（默认 100，对齐论文 Top-100）
# AISAG_RERANK_WEIGHT_STRONG=0.7          # 实体关联权重强信号阈值（默认 0.7，weight≥此值为核心关联）
# AISAG_RERANK_WEIGHT_WEAK=0.4            # 实体关联权重弱信号阈值（默认 0.4，weight<此值为背景引用）
# 事件深度轮次衰减基数（默认 0.6）：
#   depth=0(种子)→1.0, depth=1(BFS第1跳)→0.6, depth=2→0.36，跳越远可信度越低
# AISAG_RERANK_EVENT_DECAY=0.6
# AISAG_MAX_SECTIONS=5                    # 单路输出 chunk 数（默认 5，结构化+语义路径各取）
# AISAG_REWRITE_MAX_ROUNDS=5              # 查询重写保留对话轮数（默认 5，用于指代消解）

# ---- 入库流程 ----
# AISAG_EXTRACT_PARALLEL=false            # 事件抽取是否并行（默认 false；true 并发提速但吃 API 配额）
# AISAG_EXTRACT_PARALLEL_WORKERS=4        # 并行抽取 worker 数（默认 4）
# AISAG_EXTRACT_MAX_RETRIES=2             # 单 chunk 抽取最大重试次数（默认 2，应对瞬时 rate limit）
# AISAG_INGEST_CONCURRENCY=2              # 并发入库文档数上限（默认 2，防 LLM rate limit / embedding OOM）
# AISAG_RECONCILE_INTERVAL=300            # 向量-DB 对账间隔秒数（默认 300=5分钟；0=仅启动时对账一次）
# AISAG_TITLE_MAX_CHARS=100               # 事件标题字数上限（默认 100，传给 LLM 约束输出长度）
# AISAG_SUMMARY_MAX_CHARS=500             # 事件摘要字数上限（默认 500，传给 LLM 约束输出长度）
# 是否对事件摘要（summary）生成向量入库（默认 true，用于 Path B 种子事件召回；关闭=false 省算力）
# AISAG_EMBED_SUMMARY=true
# 是否启用文档级文体识别（默认 true）：
#   开启后每文档多一次 LLM 调用判断文体（news/contract/report/...），
#   驱动抽取时的边界判别规则和 role 词汇表；关闭则统一用 generic 文体，省一次 LLM 调用。
# AISAG_GENRE_DETECT=true

# ---- 日志 ----
# AISAG_LOG_LEVEL=INFO                    # 日志级别：DEBUG | INFO | WARNING | ERROR
# AISAG_LOG_DIR=./logs
# AISAG_LOG_ROTATION=500 MB               # 日志轮转大小
# AISAG_LOG_RETENTION=30 days             # 日志保留时长
# AISAG_LOG_COLORIZE=false                # 控制台彩色输出（容器环境建议关闭，避免 ANSI 乱码）