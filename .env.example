# ==============================================================
# ai_sag 环境配置模板
#
# 使用方法：
#   1. 复制此文件为 .env：
#      Linux/Mac:  cp .env.example .env
#      Windows:    copy .env.example .env
#   2. 编辑 .env，填入你自己的配置值
#   3. .env 文件不会被 git 追踪（已在 .gitignore 中）
#
# 注意：项目会自动从 config.py 所在目录逐级向上搜索 .env 文件，
#       你只需把它放在 ai_sag/ 目录下即可，无需关心仓库的 clone 路径。
# ==============================================================

# ---- 必填 ----
# MySQL 数据库连接
SAG_MYSQL_HOST=localhost
SAG_MYSQL_PORT=3306
SAG_MYSQL_DATABASE=sag
SAG_MYSQL_USER=root
SAG_MYSQL_PASSWORD=your_password

# LLM API（DeepSeek / OpenAI 兼容接口）
SAG_LLM_BASE_URL=https://api.deepseek.com
SAG_LLM_MODEL=deepseek-chat
SAG_LLM_API_KEY=sk-your-api-key-here
SAG_LLM_TIMEOUT=120
SAG_LLM_MAX_RETRIES=3

# ---- 必填：Embedding 模型 ----
# 后端选择：bge（推荐，轻量稳定）| qwen3
SAG_EMBEDDING_BACKEND=bge
SAG_EMBEDDING_DEVICE=cpu

# bge 后端模型路径（需提前下载 bge-small-zh-v1.5）
# 下载方式：modelscope download --model AI-ModelScope/bge-small-zh-v1.5
# 下载后把下面路径改为你的实际路径
SAG_BGE_MODEL_PATH=/path/to/bge-small-zh-v1.5

# qwen3 后端模型路径（选 qwen3 时才需填写）
# SAG_EMBEDDING_MODEL_PATH=/path/to/Qwen3-Embedding-0.6B

# ==============================================================
# 以下是可选配置（有合理默认值，初次使用无需修改）
# ==============================================================

# ---- 向量库 ----
# Chroma 向量库持久化路径（默认：项目根/.chroma）
# AISAG_CHROMA_PATH=./.chroma

# ---- MySQL 连接池 ----
# AISAG_MYSQL_POOL_SIZE=10
# AISAG_MYSQL_MAX_OVERFLOW=5
# AISAG_MYSQL_POOL_TIMEOUT=30
# AISAG_MYSQL_POOL_RECYCLE=3600

# ---- 文档切分 ----
# AISAG_SPLITTER_MODE=semantic
# AISAG_CHUNK_SIZE=8192
# AISAG_CHUNK_OVERLAP=800
# AISAG_BREAKPOINT_PERCENTILE=95

# ---- 文档解析 ----
# AISAG_DOC_OCR_BACKEND=rapidocr
# AISAG_DOC_OCR_IMAGES=true
# AISAG_UPLOAD_TMP_DIR=./tmp

# ---- 检索参数（SAG 论文 3.3/3.4）----
# AISAG_SIMILARITY_THRESHOLD=0.4
# AISAG_ENTITY_EXPAND_THRESHOLD=0.3
# AISAG_MAX_HOPS=2
# AISAG_SUB_STRATEGY=hopllm
# AISAG_ENTITY_FRONTIER_BUDGET=100
# AISAG_MAX_EVENTS=100
# AISAG_RERANK_TOP_K=5
# AISAG_RERANK_CANDIDATE_LIMIT=100
# AISAG_MAX_SECTIONS=5
# AISAG_FUSION=concat
# 种子事件向量召回策略：title（标题向量）| summary（摘要向量）| mixed（双路并发合并）
# AISAG_SEED_RECALL=mixed
# AISAG_COARSE_THRESHOLD=0
# AISAG_REWRITE_MAX_ROUNDS=5

# ---- 入库流程 ----
# AISAG_EXTRACT_PARALLEL=false
# AISAG_INGEST_CONCURRENCY=2
# AISAG_RECONCILE_INTERVAL=300
# 是否对事件摘要（summary）生成向量入库（默认 true，关闭设为 false）
# AISAG_EMBED_SUMMARY=true

# ---- 日志 ----
# AISAG_LOG_LEVEL=INFO
# AISAG_LOG_DIR=./logs
# AISAG_LOG_ROTATION=500 MB
# AISAG_LOG_RETENTION=30 days
# AISAG_LOG_COLORIZE=false
